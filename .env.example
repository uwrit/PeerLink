# Storage backend: "json" (default) or "mariadb"
STORAGE_BACKEND=json

# Path to JSON data files (only used when STORAGE_BACKEND=json)
JSON_DATA_PATH=data/abstracts.json
JSON_JOBS_PATH=data/jobs.json

# MariaDB (only needed when STORAGE_BACKEND=mariadb)
DATABASE_URL=mysql+pymysql://peerlink:peerlink@db:3306/peerlink
MARIADB_ROOT_PASSWORD=root

# Anthropic / Claude Agent SDK
ANTHROPIC_API_KEY=

# OpenAlex
OPENALEX_API_KEY=

# ITHS Gravity Forms API
GRAVITY_FORMS_API_CONSUMER_KEY=
GRAVITY_FORMS_API_CONSUMER_SECRET=
